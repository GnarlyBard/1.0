      reader.readAsDataURL(file);
    });
  }

  function renderPhotos() {
    const grid = document.getElementById('photoGrid');
    const empty = document.getElementById('photoEmpty');
    empty.style.display = photoItems.length ? 'none' : 'block';
    // Remove old photo items
    grid.querySelectorAll('.media-item').forEach(el => el.remove());
    photoItems.forEach((item, idx) => {
      const div = document.createElement('div');
      div.className = 'media-item';
      div.innerHTML = `
        <img src="${item.src}" alt="${item.name}" loading="lazy"/>
        <div class="media-overlay" onclick="openLightbox(${idx})"><div class="media-overlay-icon">🔍</div></div>
        <div class="media-label">${item.name}</div>
        <button class="media-delete" onclick="deletePhoto(${idx}, event)">✕</button>
      `;
      grid.appendChild(div);
    });
  }

  function deletePhoto(idx, e) {
    e.stopPropagation();
    photoItems.splice(idx, 1);
    renderPhotos();
  }

  function openLightbox(idx) {
    lightboxIndex = idx;
    const lb = document.getElementById('lightbox');
    document.getElementById('lightboxImg').src = photoItems[idx].src;
    document.getElementById('lightboxCounter').textContent = (idx+1) + ' / ' + photoItems.length;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox(e) {
    if (e && e.target !== document.getElementById('lightbox') && !e.target.classList.contains('lightbox-close')) return;
    document.getElementById('lightbox').classList.remove('open');
    document.body.style.overflow = '';
  }

  function lightboxNav(dir) {
    lightboxIndex = (lightboxIndex + dir + photoItems.length) % photoItems.length;
    document.getElementById('lightboxImg').src = photoItems[lightboxIndex].src;
    document.getElementById('lightboxCounter').textContent = (lightboxIndex+1) + ' / ' + photoItems.length;
  }

  document.addEventListener('keydown', e => {
    const lb = document.getElementById('lightbox');
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') { lb.classList.remove('open'); document.body.style.overflow = ''; }
    if (e.key === 'ArrowLeft') lightboxNav(-1);
    if (e.key === 'ArrowRight') lightboxNav(1);
  });

  // Videos
  function getEmbedUrl(url) {
    try {
      const u = new URL(url.trim());
      // YouTube
      if (u.hostname.includes('youtube.com') || u.hostname.includes('youtu.be')) {
        let id = u.searchParams.get('v') || u.pathname.split('/').pop();
        return `https://www.youtube.com/embed/${id}?rel=0`;
      }
      // Vimeo
      if (u.hostname.includes('vimeo.com')) {
        let id = u.pathname.split('/').pop();
        return `https://player.vimeo.com/video/${id}`;
      }
    } catch(e) {}
    return null;
  }

  function addVideoEmbed() {
    const input = document.getElementById('videoUrlInput');
    const url = input.value.trim();
    if (!url) return;
    const embedUrl = getEmbedUrl(url);
    if (!embedUrl) { alert('Please enter a valid YouTube or Vimeo URL.'); return; }
    const grid = document.getElementById('videoGrid');
    document.getElementById('videoEmpty').style.display = 'none';
    const div = document.createElement('div');
    div.className = 'video-embed-item';
    div.innerHTML = `
      <iframe src="${embedUrl}" allowfullscreen allow="autoplay; encrypted-media"></iframe>
      <button class="media-delete" onclick="this.parentElement.remove(); checkVideoEmpty()">✕</button>
    `;
    grid.appendChild(div);
    input.value = '';
  }

  function handleVideoUpload(files) {
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('video/')) return;
      const url = URL.createObjectURL(file);
      const grid = document.getElementById('videoGrid');
      document.getElementById('videoEmpty').style.display = 'none';
      const div = document.createElement('div');
      div.className = 'video-embed-item';
      div.innerHTML = `
        <video src="${url}" controls style="width:100%;height:100%;object-fit:cover;display:block;"></video>
        <button class="media-delete" onclick="this.parentElement.remove(); checkVideoEmpty()">✕</button>
      `;
      grid.appendChild(div);
    });
  }

  function checkVideoEmpty() {
    const grid = document.getElementById('videoGrid');
    const hasItems = grid.querySelectorAll('.video-embed-item').length > 0;
    document.getElementById('videoEmpty').style.display = hasItems ? 'none' : 'block';
  }

  // Allow Enter key on video URL input
  document.getElementById('videoUrlInput').addEventListener('keydown', e => { if (e.key === 'Enter') addVideoEmbed(); });

  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
  });

